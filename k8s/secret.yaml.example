# IMPORTANTE: No commitear este archivo con valores reales.
# Copiar como k8s/secret.yaml (ignorado por .gitignore) y rellenar con valores base64.
#
# Para encodear en Git Bash:
#   echo -n "mi_valor" | base64
# En PowerShell:
#   [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("mi_valor"))

apiVersion: v1
kind: Secret
metadata:
  name: contact-directory-secrets
  namespace: contact-directory
type: Opaque
data:
  POSTGRES_USER: <base64>
  POSTGRES_PASSWORD: <base64>
  SECRET_KEY: <base64>
  AZURE_CLIENT_ID: <base64>
  AZURE_TENANT_ID: <base64>
  AZURE_CLIENT_SECRET: <base64>
