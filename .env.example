# =============================================================================
# CONTACT DIRECTORY - Variables de Entorno
# Copiar a .env y completar con valores reales
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=contactdb_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=contact_directory
POSTGRES_HOST=db
POSTGRES_PORT=5432

# URL completa (construida automáticamente en config.py, pero puede sobreescribirse)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# --- FastAPI / Backend ---
SECRET_KEY=changeme_32_chars_minimum_random_string_here
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development
# development | production
LOG_LEVEL=INFO

# --- Azure Active Directory (MSAL) ---
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your_azure_client_secret_here
AZURE_REDIRECT_URI=http://localhost/auth/callback
# Scopes adicionales separados por espacio (openid profile email ya están incluidos)
AZURE_SCOPES=User.Read

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# --- Frontend (React) ---
REACT_APP_API_URL=http://localhost/api
REACT_APP_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
REACT_APP_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
REACT_APP_AZURE_REDIRECT_URI=http://localhost/auth/callback

# --- Nginx ---
NGINX_HOST=localhost
NGINX_PORT=80

# --- Uploads ---
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=/app/uploads

# --- CORS ---
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80
